generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
}

enum AssistantStatus {
  PROVISIONING
  ACTIVE
  DISABLED
}

enum OnboardingStatus {
  ACCOUNT_CREATED
  TELEGRAM_GROUP_BINDING_PENDING
  TELEGRAM_GROUP_BINDING_IN_PROGRESS
  COMPLETE
}

enum OnboardingStep {
  ACCOUNT_SETUP
  TELEGRAM_GROUP_BINDING
  COMPLETE
}

enum MessagingPlatform {
  TELEGRAM
}

enum KinEventCategory {
  PLAN
  EVENT
  TASK
  PREFERENCE
  DECISION
  QUESTION
  ONBOARDING
  UNKNOWN
}

enum GroupBindingStatus {
  DM_STARTED
  BOT_ADDED
  ACTIVE
  FAILED
}

enum TaskKind {
  REMINDER
  GROCERY_ITEM
  LIST_ITEM
  FOLLOW_UP
}

enum TaskStatus {
  OPEN
  DONE
  CANCELED
}

enum ReminderStatus {
  SCHEDULED
  FIRED
  CANCELED
  FAILED
}

enum ReminderClaimStatus {
  CLAIMED
}

model User {
  id         String   @id @default(cuid())
  cognitoSub String?  @unique
  name       String?
  email      String   @unique
  password   String?
  role       UserRole @default(OWNER)
  createdAt  DateTime @default(now())

  ownedFamilies Family[] @relation("FamilyOwner")
}

model Family {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  ownerId String
  owner   User   @relation("FamilyOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  assistant       Assistant?
  onboardingState OnboardingState?
  groupBindings   GroupBinding[]
  tasks           Task[]
  reminders       Reminder[]

  @@index([ownerId])
}

model Assistant {
  id          String          @id @default(cuid())
  name        String
  status      AssistantStatus @default(PROVISIONING)
  runtimeType String          @default("openclaw")
  createdAt   DateTime        @default(now())

  familyId String @unique
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model OnboardingState {
  id          String           @id @default(cuid())
  status      OnboardingStatus @default(ACCOUNT_CREATED)
  currentStep OnboardingStep   @default(ACCOUNT_SETUP)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  familyId String @unique
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
}

model GroupBinding {
  id                  String             @id @default(cuid())
  platform            MessagingPlatform  @default(TELEGRAM)
  status              GroupBindingStatus @default(DM_STARTED)
  groupName           String?
  externalGroupId     String?            @unique
  onboardingToken     String             @unique
  botUsername         String?
  telegramDmUserId    String?
  telegramDmChatId    String?
  telegramDmUsername  String?
  telegramDmFirstName String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  verifiedAt          DateTime?

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  tasks     Task[]
  reminders Reminder[]

  @@index([familyId, status])
  @@index([telegramDmUserId, status])
}

model KinEvent {
  id             String            @id @default(cuid())
  platform       MessagingPlatform
  category       KinEventCategory
  dedupeKey      String            @unique
  updateId       String?
  kind           String
  scope          String?
  routeDecision  String
  routeReason    String
  chatId         String?
  chatType       String?
  chatTitle      String?
  fromUserId     String?
  fromUsername   String?
  fromFirstName  String?
  messageId      String?
  text           String?
  command        String?
  oldStatus      String?
  newStatus      String?
  familyId       String?
  groupBindingId String?
  raw            Json
  createdAt      DateTime          @default(now())

  sourceTasks     Task[]     @relation("TaskSourceKinEvent")
  sourceReminders Reminder[] @relation("ReminderSourceKinEvent")

  @@index([familyId, createdAt])
  @@index([familyId, category, createdAt])
  @@index([groupBindingId, createdAt])
  @@index([platform, createdAt])
  @@index([platform, category, createdAt])
  @@index([platform, chatId, createdAt])
  @@index([updateId])
}

model Task {
  id        String     @id @default(cuid())
  kind      TaskKind
  status    TaskStatus @default(OPEN)
  text      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  groupBindingId String?
  groupBinding   GroupBinding? @relation(fields: [groupBindingId], references: [id], onDelete: SetNull)

  sourceKinEventId String?
  sourceKinEvent   KinEvent? @relation("TaskSourceKinEvent", fields: [sourceKinEventId], references: [id], onDelete: SetNull)

  reminders Reminder[]

  @@index([familyId, status, createdAt])
  @@index([familyId, kind, createdAt])
  @@index([groupBindingId, createdAt])
  @@index([sourceKinEventId])
}

model Reminder {
  id               String               @id @default(cuid())
  status           ReminderStatus       @default(SCHEDULED)
  scheduledFor     DateTime
  scheduleName     String?              @unique
  scheduledBy      String?
  canceledAt       DateTime?
  claimStatus      ReminderClaimStatus?
  claimedAt        DateTime?
  firedAt          DateTime?
  failedAt         DateTime?
  lastError        String?
  deliveryAttempts Int                  @default(0)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  familyId String
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  groupBindingId String?
  groupBinding   GroupBinding? @relation(fields: [groupBindingId], references: [id], onDelete: SetNull)

  sourceKinEventId String?
  sourceKinEvent   KinEvent? @relation("ReminderSourceKinEvent", fields: [sourceKinEventId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([familyId, status, scheduledFor])
  @@index([groupBindingId, scheduledFor])
  @@index([sourceKinEventId])
}
