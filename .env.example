# Database
DATABASE_URL=postgresql://kin:kinpassword@db:5432/kin

# OpenClaw transport
OPENCLAW_TRANSPORT_MODE=remote-gateway
OPENCLAW_GATEWAY_URL=https://your-openclaw-gateway.example.com
OPENCLAW_GATEWAY_TOKEN=replace-me
OPENCLAW_BIN=openclaw

# Telegram
TELEGRAM_BOT_TOKEN=replace-me
KIN_TELEGRAM_BOT_USERNAME=your_bot_username
KIN_TELEGRAM_WEBHOOK_SECRET=replace-me

#Scheduler / SQS
KIN_REMINDER_SCHEDULER_ROLE_ARN=arn:aws:iam::609425362905:role/Kin_Scheduler
KIN_REMINDER_SCHEDULER_GROUP_NAME=default
KIN_REMINDER_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/609425362905/kin-reminders

# Cognito / auth
NEXT_PUBLIC_AWS_REGION=us-east-2
AWS_REGION=us-east-2
KIN_COGNITO_USER_POOL_ID=replace-me
NEXT_PUBLIC_COGNITO_USER_POOL_ID=replace-me
NEXT_PUBLIC_COGNITO_USER_POOL_CLIENT_ID=replace-me
